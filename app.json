{
  "expo": {
    "name": "Akyl Cheshmesi",
    "slug": "akyl-cheshmesi",
    "owner": "aga_sila",
    "scheme": "akylchat",
    "version": "1.0.6",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/images/icon.png",

    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#061A12"
    },

    "assetBundlePatterns": ["**/*"],

    "experiments": {
      "typedRoutes": true
    },

    "plugins": [
      "expo-router",
      "expo-dev-client",
      "expo-notifications",
      [
        "expo-sqlite",
        {
          "enableFTS": true,
          "useSQLCipher": false
        }
      ],
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Разрешите Akyl Cheshmesi доступ к фото и видео, чтобы отправлять медиа в чат."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Разрешите Akyl Cheshmesi использовать камеру для видео-звонков и видео-сообщений.",
          "microphonePermission": "Разрешите Akyl Cheshmesi использовать микрофон для аудио-звонков, видео-звонков и голосовых сообщений.",
          "recordAudioAndroid": true
        }
      ]
    ],

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.akylchat.app",
      "buildNumber": "10",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"],
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Разрешите Akyl Cheshmesi использовать камеру для видео-звонков.",
        "NSMicrophoneUsageDescription": "Разрешите Akyl Cheshmesi использовать микрофон для звонков и голосовых сообщений.",
        "NSPhotoLibraryUsageDescription": "Разрешите Akyl Cheshmesi доступ к фото и видео, чтобы отправлять медиа в чат.",
        "NSPhotoLibraryAddUsageDescription": "Разрешите Akyl Cheshmesi сохранять медиафайлы при необходимости."
      }
    },

    "android": {
      "package": "com.akylchat.app",
      "googleServicesFile": "./google-services.json",
      "version": "1.0.6",
      "versionCode": 10,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#061A12"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "POST_NOTIFICATIONS",
        "RECORD_AUDIO",
        "CAMERA",
        "MODIFY_AUDIO_SETTINGS",
        "WAKE_LOCK",
        "FOREGROUND_SERVICE",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "READ_EXTERNAL_STORAGE"
      ]
    },

    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },

    "extra": {
      "apiBaseUrl": "https://akyl-cheshmesi.ru/api/v1",
      "wsBaseUrl": "wss://akyl-cheshmesi.ru/ws",
      "callWsBaseUrl": "wss://akyl-cheshmesi.ru/ws/calls",
      "callIceServers": "stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302,turn:turn.akyl-cheshmesi.ru:3478?transport=udp,turn:turn.akyl-cheshmesi.ru:3478?transport=tcp,turns:turn.akyl-cheshmesi.ru:5349?transport=tcp",
      "callTurnUsername": "akylturn",
      "callTurnCredential": "PASTE_YOUR_TURN_PASSWORD_HERE",
      "pushTokenSyncPath": "/push-tokens/",
      "eas": {
        "projectId": "1d056ce0-1890-4429-97f7-31e739a1e023"
      }
    },

    "runtimeVersion": "1.0.6"
  }
}
